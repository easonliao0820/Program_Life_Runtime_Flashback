[sub_resource type="Shader" id="Shader_runbtn"]
code = "shader_type canvas_item;
uniform float radius_px : hint_range(0, 100) = 10.0;
void fragment() {
	vec2 size = 1.0 / TEXTURE_PIXEL_SIZE;
	vec2 pixel_pos = UV * size;
	vec2 corner = abs(pixel_pos - size * 0.5) - (size * 0.5 - radius_px);
	float d = length(max(corner, vec2(0.0))) - radius_px;
	float alpha = 1.0 - smoothstep(radius_px - 1.0, radius_px + 1.0, d);
	COLOR = texture(TEXTURE, UV);
	COLOR.a *= alpha;
}"

