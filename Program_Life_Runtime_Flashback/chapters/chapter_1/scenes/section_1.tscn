theme_override_constants/separation = 10

[node name="SectionTitle" type="Label" parent="TextbookLayer/TextbookPanel/WindowContainer/MarginContainer/VBox/Body/RightCol" unique_id=568125968]
layout_mode = 2
theme_override_colors/font_color = Color(0.972549, 0.815686, 0.552941, 1)
theme_override_font_sizes/font_size = 18
text = "💻 程式概念：輸出與字串"

[node name="ProgText" type="RichTextLabel" parent="TextbookLayer/TextbookPanel/WindowContainer/MarginContainer/VBox/Body/RightCol" unique_id=488575339]
layout_mode = 2
size_flags_vertical = 3
theme_override_colors/default_color = Color(0.901961, 0.901961, 0.901961, 1)
theme_override_font_sizes/normal_font_size = 15
bbcode_enabled = true
text = "[b]1. print() 函式[/b]
在 Python 中，[code]print()[/code] 是用來將資料「顯示」或「輸出」到螢幕上的基本指令。
例如：[code]print(\"哈囉\")[/code] 會在螢幕印出 哈囉。

[b]2. 字串 (String)[/b]
電腦無法直接看懂人類的文字。我們必須使用雙引號 [code]\"[/code] 或單引號 [code]'[/code] 將文字包起來，這在程式中稱為「字串」。
• 正確：[code]print(\"小艾\")[/code]
• 錯誤：[code]print(小艾)[/code] （電腦會看不懂「小艾」而報錯）

[b]💡 小提示[/b]
括號 [code]()[/code] 與引號 [code]\"\"[/code] 都必須是成對出現的半形符號喔！"

