[node name="StoryText" type="RichTextLabel" parent="TextbookLayer/TextbookPanel/WindowContainer/MarginContainer/VBox/Body/LeftCol" unique_id=1659052038]
layout_mode = 2
size_flags_vertical = 3
theme_override_colors/default_color = Color(0.901961, 0.901961, 0.901961, 1)
theme_override_font_sizes/normal_font_size = 15
bbcode_enabled = true
text = "你剛誕生在這個世界上，卻驚奇地發現自己無法發出任何哭聲。

虛空中浮現出神秘的投影—--- 他告訴你：
[color=#F8D08D]『你是這個世界上獨一無二的存在，你的世界有著獨特的語言和與眾不同的規則。想要發出聲音的話，就學我怎麼做。』[/color]

為了在這世界發出你的第一聲，你必須透過 Python 的 [code]print()[/code] 函式向世界宣告你的存在！"

[node name="VSeparator" type="VSeparator" parent="TextbookLayer/TextbookPanel/WindowContainer/MarginContainer/VBox/Body" unique_id=704923239]
