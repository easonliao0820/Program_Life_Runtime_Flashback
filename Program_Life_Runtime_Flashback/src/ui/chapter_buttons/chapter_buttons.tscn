[gd_scene format=3]

[ext_resource type="Script" path="res://src/ui/chapter_buttons/chapter_buttons.gd" id="1_script"]
[ext_resource type="Texture2D" path="res://chapters/chapter_1/images/knowledgeButton.png" id="2_knowledge"]

[sub_resource type="Shader" id="Shader_rounded"]
code = "shader_type canvas_item;
uniform float radius_px : hint_range(0, 100) = 12.0;
void fragment() {
	vec2 size = 1.0 / TEXTURE_PIXEL_SIZE;
	vec2 pixel_pos = UV * size;
	vec2 corner = abs(pixel_pos - size * 0.5) - (size * 0.5 - radius_px);
	float d = length(max(corner, vec2(0.0))) - radius_px;
	float alpha = 1.0 - smoothstep(radius_px - 1.0, radius_px + 1.0, d);
	COLOR = texture(TEXTURE, UV);
	COLOR.a *= alpha;
}"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_rounded"]
shader = SubResource("Shader_rounded")
shader_parameter/radius_px = 12.0

